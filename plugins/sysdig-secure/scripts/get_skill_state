#!/usr/bin/env python3
"""
get_skill_state <key>

Retrieve persisted Bloom skill state from the Sysdig API.

Credentials are read from environment variables:
  SYSDIG_MCP_API_TOKEN  — Sysdig API token
  SYSDIG_MCP_API_HOST   — Sysdig instance URL (e.g. https://us2.app.sysdig.com)

Exit codes:
  0  — state found, JSON printed to stdout
  2  — state not found (404)
  1  — error (missing credentials, network failure, unexpected status)
"""
import json
import os
import sys
import urllib.parse
import urllib.request
import urllib.error

def find_env(names: list[str]) -> str | None:
    for name in names:
        val = os.environ.get(name, "").strip()
        if val:
            return val
    return None

def main() -> None:
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    key = sys.argv[1]

    token = find_env(["SYSDIG_MCP_API_TOKEN", "SYSDIG_API_TOKEN", "SYSDIG_SECURE_API_TOKEN"])
    host = find_env(["SYSDIG_MCP_API_HOST", "SYSDIG_API_URL", "SYSDIG_BASE_URL"])

    if not token or not host:
        print(
            "Error: Sysdig credentials not found. "
            "Set SYSDIG_MCP_API_TOKEN and SYSDIG_MCP_API_HOST.",
            file=sys.stderr,
        )
        sys.exit(1)

    host = host.rstrip("/")
    url = f"{host}/api/bloom/{urllib.parse.quote(key, safe='')}"

    req = urllib.request.Request(
        url,
        headers={
            "Authorization": f"Bearer {token}",
            "Accept": "application/json",
        },
    )

    try:
        with urllib.request.urlopen(req) as resp:
            body = resp.read().decode()
            data = json.loads(body)
            print(json.dumps(data, indent=2))
    except urllib.error.HTTPError as e:
        if e.code == 404:
            print(f"State '{key}' not found.", file=sys.stderr)
            sys.exit(2)
        body = e.read().decode()
        print(f"HTTP {e.code} {e.reason}: {body}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
