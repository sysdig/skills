{
  "mcpServers": {
    "sysdig": {
      "command": "npx",
      "args": ["-y", "@sysdig/secure-mcp-server"],
      "env": {
        "SYSDIG_MCP_TRANSPORT": "stdio",
        "SYSDIG_MCP_API_TOKEN": "${SYSDIG_MCP_API_TOKEN}",
        "SYSDIG_MCP_API_HOST": "${SYSDIG_MCP_API_HOST}"
      }
    }
  }
}
